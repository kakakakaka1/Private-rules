{
  "name": "private-rules-worker",
  "version": "1.0.3",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "type": "module",
  "description": "Private self-hosted rules console for Cloudflare Workers and Docker Compose.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:node": "tsx watch src/runtimes/node.ts",
    "start": "node dist/server/node.js",
    "build": "pnpm build:client && pnpm build:server && pnpm prepare:cloudflare-deploy",
    "build:client": "vite build",
    "build:server": "tsup src/runtimes/node.ts --format esm --platform node --out-dir dist/server --clean --external better-sqlite3",
    "prepare:cloudflare-deploy": "node scripts/prepare-cloudflare-deploy.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:api": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "deploy": "wrangler deploy --keep-vars",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.4.1",
    "hono": "^4.8.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.11.6",
    "@playwright/test": "^1.58.2",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "opencc-js": "^1.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.5",
    "vitest": "^4.0.18",
    "miniflare": "^4.20260702.0",
    "wrangler": "^4.24.0"
  }
}
